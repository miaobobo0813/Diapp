<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Diapp.EditDiary"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Diapp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel>
            <Grid Padding="40">
                <Grid x:Name="gridShadow"/>
                <Border CornerRadius="5" 
                        Translation="0,0,30" 
                        Loaded="Border_Loaded" 
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        Width="1000">
                    <Border.Shadow>
                        <ThemeShadow x:Name="cardShadow"/>
                    </Border.Shadow>
                    <StackPanel Spacing="10" Margin="50" VerticalAlignment="Center">
                        <TextBlock Text="新日记" FontSize="25" FontWeight="Bold"/>
                        <TextBox x:Name="Title"
                                 PlaceholderText="输入日记标题 (建议不要创建同名日记)..."/>
                        <RichEditBox x:Name="PlainContent"
                                     MinHeight="180"
                                     PlaceholderText="输入日记..."/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="SaveButton"
                                    Content="保存"
                                    Click="SaveButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
            <Rectangle Opacity="0" VerticalAlignment="Stretch"/>
        </StackPanel>
    </ScrollViewer>
</Page>