<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Diapp.Warning"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Diapp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid x:Name="gridShadow" />
        <Border CornerRadius="5" Translation="0,0,30" Loaded="Border_Loaded" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Width="500" Height="100">
            <Border.Shadow>
                <ThemeShadow x:Name="cardShadow"/>
            </Border.Shadow>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
                <FontIcon Glyph="&#xE72E;" FontSize="30"/>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="日记已锁定" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="前往边栏中的“更改加密密钥”输入密码以解锁日记。"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
    
</Page>
